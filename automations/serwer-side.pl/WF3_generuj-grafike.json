    },
    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"dalle_prompt\": \"Flat vector neo-brutalist social media graphic. Dark navy background #0f172a. Large cyan text '30% DANYCH ZNIKA'. Small friendly robot mascot in bottom right corner: geometric compact body, dark navy with cyan accents, flat style. Hard 2px white border with 4px offset shadow. No gradients. Clean and sharp. 1080x1080px.\",\n  \"tekst_na_grafice\": \"30% danych znika. Codziennie.\",\n  \"opis_grafiki\": \"Grafika z cyfrą 30% na ciemnym tle z robocikiem\"\n}"
      },
