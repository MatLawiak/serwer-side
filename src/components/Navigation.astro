---
const currentPath = Astro.url.pathname;

const uslugiSubmenu = [
  { href: '/uslugi/meta-power-vps', label: 'Meta Power VPS' },
  { href: '/uslugi/google-power-vps', label: 'Google Power VPS' },
  { href: '/uslugi/automatyzacje-vps', label: 'Dedykowane automatyzacje VPS' },
];

const links = [
  { href: '/', label: 'Strona główna' },
  { href: '/uslugi', label: 'Usługi', hasSubmenu: true },
  { href: '/wiedza', label: 'Wiedza' },
  { href: '/o-mnie', label: 'O mnie' },
  { href: '/kontakt', label: 'Kontakt' },
];

const isUslugiActive = currentPath === '/uslugi' || currentPath.startsWith('/uslugi/');
---

<div id="nav-sentinel" class="absolute top-0 h-[50px] w-full pointer-events-none" aria-hidden="true"></div>

<nav id="main-nav" class="bg-primary text-white sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2" id="nav-logo">
        <img src="/logo-server-side.png" alt="serwer-side.pl" class="h-10 w-auto" />
        <div class="hidden md:flex flex-col leading-tight">
          <span class="font-bold text-lg leading-none">serwer-side.pl</span>
          <span class="text-xs text-gray-400 font-normal leading-none">Ekspert server-side tracking</span>
        </div>
      </a>

      {/* Desktop navigation */}
      <div class="hidden md:flex items-center gap-6">
        {links.map((link) => (
          link.hasSubmenu ? (
            <div class="relative group">
              <a
                href={link.href}
                class:list={[
                  'nav-link text-sm font-medium transition-colors hover:text-accent inline-flex items-center gap-1',
                  isUslugiActive ? 'text-accent' : 'text-gray-300',
                ]}
              >
                {link.label}
                <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              {/* Dropdown */}
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 min-w-[280px]">
                <div class="bg-white rounded-lg shadow-xl border-2 border-primary/10 py-2">
                  {uslugiSubmenu.map((sub) => (
                    <a
                      href={sub.href}
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        currentPath === sub.href
                          ? 'text-accent font-semibold bg-accent/5'
                          : 'text-gray-700 hover:bg-stone-50 hover:text-accent',
                      ]}
                    >
                      {sub.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'nav-link text-sm font-medium transition-colors hover:text-accent',
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-accent'
                  : 'text-gray-300',
              ]}
            >
              {link.label}
            </a>
          )
        ))}
      </div>

      {/* Mobile hamburger */}
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md hover:bg-white/10 transition-colors"
        aria-label="Otwórz menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10">
    <div class="px-4 py-3 space-y-1">
      {links.map((link) => (
        link.hasSubmenu ? (
          <details class="group">
            <summary class:list={[
              'flex items-center justify-between px-3 py-2 rounded-md text-sm font-medium transition-colors hover:bg-white/10 cursor-pointer list-none',
              isUslugiActive ? 'text-accent' : 'text-gray-300',
            ]}>
              <span>{link.label}</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="pl-4 mt-1 space-y-1 border-l-2 border-white/10">
              {uslugiSubmenu.map((sub) => (
                <a
                  href={sub.href}
                  class:list={[
                    'block px-3 py-2 rounded-md text-sm transition-colors hover:bg-white/10',
                    currentPath === sub.href ? 'text-accent font-semibold' : 'text-gray-300',
                  ]}
                >
                  {sub.label}
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={link.href}
            class:list={[
              'block px-3 py-2 rounded-md text-sm font-medium transition-colors hover:bg-white/10',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-accent'
                : 'text-gray-300',
            ]}
          >
            {link.label}
          </a>
        )
      ))}
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // Nav scroll effect
  const nav = document.getElementById('main-nav');
  const navSentinel = document.getElementById('nav-sentinel');
  const logo = document.getElementById('nav-logo');

  if (nav && navSentinel) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const scrolled = !entry.isIntersecting;
          nav.classList.toggle('bg-white/95', scrolled);
          nav.classList.toggle('backdrop-blur-sm', scrolled);
          nav.classList.toggle('border-b-2', scrolled);
          nav.classList.toggle('border-primary/10', scrolled);
          nav.classList.toggle('bg-primary', !scrolled);

          const logoText = logo?.querySelector('span');
          if (logoText) logoText.classList.toggle('text-primary', scrolled);

          nav.querySelectorAll('.nav-link:not(.text-accent)').forEach((a) => {
            a.classList.toggle('text-gray-600', scrolled);
            a.classList.toggle('text-gray-300', !scrolled);
          });
        });
      },
      { threshold: 0 }
    );
    observer.observe(navSentinel);
  }
</script>
