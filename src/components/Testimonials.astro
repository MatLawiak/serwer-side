---
const testimonials = [
  {
    quote: 'Po wdrożeniu server-side odzyskaliśmy 34% brakujących transakcji w GA4. Algorytm Meta wreszcie optymalizuje na pełnych danych.',
    name: 'Klient e-commerce',
    detail: 'Obrót 300k+/mies.',
  },
  {
    quote: 'Nie wiedzieliśmy, że tracimy tyle danych. Audyt pokazał dokładnie gdzie i ile. Wdrożenie zwróciło się w pierwszym miesiącu.',
    name: 'Klient lead generation',
    detail: 'Branża deweloperska',
  },
  {
    quote: 'Wreszcie mamy jedno źródło prawdy o konwersjach. Meta, Google Ads i GA4 raportują spójne dane.',
    name: 'Agencja marketingowa',
    detail: '12 klientów e-commerce',
  },
];
---

<section class="py-16 md:py-20 bg-primary text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">Co mówią klienci</h2>

    <div class="flex md:grid md:grid-cols-3 gap-6 overflow-x-auto snap-x snap-mandatory pb-4 -mx-4 px-4 md:mx-0 md:px-0 md:overflow-visible">
      {testimonials.map((t) => (
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 md:p-8 min-w-[300px] md:min-w-0 snap-center shrink-0 flex flex-col">
          <span class="text-4xl text-accent/40 leading-none mb-4" aria-hidden="true">"</span>
          <p class="text-gray-300 italic flex-1 mb-6">{t.quote}</p>
          <div class="border-t border-white/10 pt-4">
            <p class="font-semibold text-white">{t.name}</p>
            <p class="text-sm text-gray-500">{t.detail}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-xs text-gray-600 text-center mt-6">
      * Wyniki na podstawie pilotażowych wdrożeń. Case studies wkrótce.
    </p>
  </div>
</section>
