---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Strona nie znaleziona | serwer-side.pl"
  description="Strona, której szukasz, nie istnieje."
>
  <section class="py-20 md:py-32">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-6xl font-extrabold text-accent mb-4">404</p>
      <h1 class="text-2xl md:text-3xl font-bold mb-4">Strona nie znaleziona</h1>
      <p class="text-gray-600 mb-8">
        Wygląda na to, że ta strona nie istnieje. Możliwe, że link jest nieaktualny
        lub adres został wpisany niepoprawnie.
      </p>
      <a
        href="/"
        class="inline-block bg-accent hover:bg-accent-dark text-white font-semibold px-6 py-3 rounded-lg btn-brutal"
      >
        Wróć na stronę główną
      </a>
    </div>
  </section>
</Layout>
