---
import Layout from '../layouts/Layout.astro';
import HeroNew from '../components/HeroNew.astro';
import DataFlowAnimated from '../components/DataFlowAnimated.astro';
import BarriersSection from '../components/BarriersSection.astro';
import CaseStudyAnon from '../components/CaseStudyAnon.astro';
import ModularStack from '../components/ModularStack.astro';
import Testimonials from '../components/Testimonials.astro';
---

<Layout
  title="Server-Side Tracking dla Meta i Google Ads | serwer-side.pl"
  description="Twoje kampanie tracą 30-50% konwersji przez AdBlockery, iOS i Safari. Server-Side Tracking przywraca te dane do algorytmu. Sprawdź ile tracisz."
>

  {/* 1. Hero — ból klienta + liczniki */}
  <HeroNew />

  <div class="bg-primary"><div class="max-w-6xl mx-auto px-4 sm:px-6"><hr class="border-white/10" /></div></div>

  {/* 2. Animowany schemat przepływu danych */}
  <DataFlowAnimated />

  <div class="bg-primary"><div class="max-w-6xl mx-auto px-4 sm:px-6"><hr class="border-white/10" /></div></div>

  {/* 3. Cztery bariery = cztery powody do wdrożenia */}
  <BarriersSection />

  <div class="bg-primary"><div class="max-w-6xl mx-auto px-4 sm:px-6"><hr class="border-white/10" /></div></div>

  {/* 4. Case study (anonimowe) z animowanymi wykresami */}
  <CaseStudyAnon />

  <div class="bg-primary"><div class="max-w-6xl mx-auto px-4 sm:px-6"><hr class="border-white/10" /></div></div>

  {/* 5. Modułowy stack VPS */}
  <ModularStack />

  <div class="bg-primary"><div class="max-w-6xl mx-auto px-4 sm:px-6"><hr class="border-white/10" /></div></div>

  {/* 6. Testimoniale */}
  <Testimonials />

  <div class="bg-primary"><div class="max-w-6xl mx-auto px-4 sm:px-6"><hr class="border-white/10" /></div></div>

  {/* 7. CTA końcowe */}
  <section class="py-20 md:py-28 bg-primary text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">

      <span class="inline-block bg-accent/20 text-accent text-xs font-semibold px-3 py-1 rounded-full mb-6 uppercase tracking-wider">
        Bezpłatna diagnoza
      </span>

      <h2 class="text-2xl md:text-4xl font-extrabold mb-5 leading-tight">
        Sprawdź ile konwersji<br/>
        traci Twoja kampania.
      </h2>

      <p class="text-gray-300 mb-3 text-lg max-w-xl mx-auto">
        30 minut. Bezpłatnie. Konkretna diagnoza, nie sprzedaż.
      </p>
      <p class="text-gray-500 text-sm mb-10 max-w-lg mx-auto">
        Sprawdzę EMQ Twoich kampanii, pokrycie zdarzeń i deduplikację Pixel/CAPI. Powiem konkretnie co traci Twój tracking i czy wdrożenie ma sens w Twoim przypadku.
      </p>

      <a
        href="/kontakt"
        class="inline-block bg-accent hover:bg-accent-dark text-white font-semibold px-10 py-4 rounded-lg text-lg btn-brutal-light"
      >
        Umów bezpłatny audyt EMQ
      </a>

      <p class="text-xs text-gray-600 mt-4">
        Bez umowy. Bez zobowiązań. Odpowiadam w 24h.
      </p>

      {/* Linki pomocnicze */}
      <div class="mt-10 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
        <a href="/uslugi" class="text-gray-400 hover:text-accent transition-colors">
          Zobacz wszystkie usługi
        </a>
        <span class="text-white/20">|</span>
        <a href="/wiedza" class="text-gray-400 hover:text-accent transition-colors">
          Baza wiedzy
        </a>
        <span class="text-white/20">|</span>
        <a href="/o-mnie" class="text-gray-400 hover:text-accent transition-colors">
          O mnie
        </a>
      </div>

    </div>
  </section>

</Layout>
