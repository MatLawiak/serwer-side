---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kontakt — Umów bezpłatną diagnozę | server-side.pl"
  description="Skontaktuj się, aby umówić bezpłatną 30-minutową rozmowę diagnostyczną. Sprawdzimy, ile danych traci Twój tracking."
>
  <section class="bg-primary text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">Kontakt</h1>
      <p class="text-gray-300 text-lg">
        Odpowiadam w ciągu 24h. Pierwsza rozmowa diagnostyczna (30&nbsp;min) jest bezpłatna.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-5 gap-12">
        {/* Formularz */}
        <div class="md:col-span-3">
          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                Imię i nazwisko *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-colors"
                placeholder="Jan Kowalski"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-colors"
                placeholder="jan@firma.pl"
              />
            </div>

            <div>
              <label for="url" class="block text-sm font-medium text-gray-700 mb-1">
                URL strony / sklepu
              </label>
              <input
                type="url"
                id="url"
                name="url"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-colors"
                placeholder="https://mojsklep.pl"
              />
            </div>

            <div>
              <label for="budget" class="block text-sm font-medium text-gray-700 mb-1">
                Budżet reklamowy miesięczny
              </label>
              <select
                id="budget"
                name="budget"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-colors bg-white"
              >
                <option value="">Wybierz zakres</option>
                <option value="<5k">Poniżej 5 000 zł</option>
                <option value="5-15k">5 000 – 15 000 zł</option>
                <option value="15-50k">15 000 – 50 000 zł</option>
                <option value=">50k">Powyżej 50 000 zł</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                Wiadomość
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-colors resize-y"
                placeholder="Opisz swoją sytuację lub zadaj pytanie..."
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="rodo"
                name="rodo"
                required
                class="mt-1 w-4 h-4 text-accent border-gray-300 rounded focus:ring-accent"
              />
              <label for="rodo" class="text-xs text-gray-500 leading-relaxed">
                Wyrażam zgodę na przetwarzanie moich danych osobowych w celu obsługi zapytania
                kontaktowego, zgodnie z&nbsp;Rozporządzeniem Parlamentu Europejskiego i&nbsp;Rady (UE) 2016/679 (RODO). *
              </label>
            </div>

            <button
              type="submit"
              class="w-full bg-accent hover:bg-accent-dark text-white font-semibold py-4 rounded-lg text-lg btn-brutal"
            >
              Wyślij wiadomość
            </button>

            {/* Komunikaty */}
            <div id="form-success" class="hidden p-4 bg-green-50 border-2 border-green-200 rounded-xl text-green-700 text-sm text-center">
              Dziękuję! Twoja wiadomość została wysłana. Odezwę się w ciągu 24h.
            </div>
            <div id="form-error" class="hidden p-4 bg-red-50 border-2 border-red-200 rounded-xl text-red-700 text-sm text-center">
              Wystąpił błąd podczas wysyłania. Spróbuj ponownie lub napisz bezpośrednio na email.
            </div>
          </form>
        </div>

        {/* Dane kontaktowe */}
        <div class="md:col-span-2">
          <div class="bg-stone-50 rounded-xl p-6 card-brutal-static">
            <h2 class="font-bold text-lg mb-4">Dane kontaktowe</h2>
            <div class="space-y-4 text-sm">
              <div>
                <p class="text-gray-500 mb-1">Email</p>
                <a href="mailto:mat.lawiak7195@gmail.com" class="text-accent hover:underline font-medium">
                  mat.lawiak7195@gmail.com
                </a>
              </div>
              <div>
                <p class="text-gray-500 mb-1">LinkedIn</p>
                <a
                  href="https://www.linkedin.com/in/mateuszlawiak/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline font-medium"
                >
                  linkedin.com/in/mateuszlawiak
                </a>
              </div>
            </div>
            <hr class="my-6 border-gray-200" />
            <div class="text-sm text-gray-600 space-y-2">
              <p>⏱️ Odpowiadam w ciągu <strong>24 godzin</strong></p>
              <p>📞 Pierwsza rozmowa: <strong>30 min, bezpłatnie</strong></p>
              <p>📊 Omówimy Twój obecny tracking i&nbsp;potencjał do poprawy</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    }
  });
</script>
