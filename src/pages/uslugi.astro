---
import Layout from '../layouts/Layout.astro';
import TrustBadges from '../components/TrustBadges.astro';
import PackageComparison from '../components/PackageComparison.astro';

const faq = [
  {
    q: 'Ile trwa wdrożenie server-side tracking?',
    a: 'W zależności od pakietu — od 3 dni (audyt) do 14 dni roboczych (pakiet PRO). Czas zależy też od złożoności Twojego stacku technologicznego i szybkości dostarczenia dostępów.',
  },
  {
    q: 'Czy server-side tracking jest zgodny z RODO?',
    a: 'Tak. Server-side tracking daje Ci większą kontrolę nad danymi niż tracking client-side. W połączeniu z Consent Mode v2 możesz w pełni respektować zgody użytkowników, jednocześnie odzyskując dane modelowane.',
  },
  {
    q: 'Czy potrzebuję swojego serwera?',
    a: 'Nie. W pakietach BASIC i PRO wykorzystuję Stape.io jako hosting GTM Server-Side. To zarządzana usługa — nie musisz konfigurować żadnej infrastruktury. Konfiguruję też custom domain na Twojej domenie.',
  },
  {
    q: 'Jaki budżet reklamowy uzasadnia wdrożenie?',
    a: 'Jeśli wydajesz na reklamy więcej niż 5 000 zł miesięcznie, strata 30–40% danych konwersji realnie wpływa na Twój ROAS. Im wyższy budżet, tym większy sens wdrożenia.',
  },
  {
    q: 'Co jeśli nie wiem, który pakiet wybrać?',
    a: 'Zacznij od bezpłatnej rozmowy diagnostycznej. W 30 minut ocenimy, na jakim etapie jest Twój tracking i jaki zakres wdrożenia da Ci najlepsze efekty.',
  },
];
---

<Layout
  title="Usługi — Wdrożenia server-side tracking | server-side.pl"
  description="Pakiety wdrożeniowe server-side tracking: audyt danych, GTM Server-Side, GA4, Meta CAPI, Google Ads Enhanced Conversions, TikTok Events API."
>
  {/* Header */}
  <section class="bg-primary text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">Usługi i pakiety wdrożeniowe</h1>
      <p class="text-gray-300 text-lg">
        Od diagnozy po pełne wdrożenie server-side tracking z&nbsp;opieką.
      </p>
    </div>
  </section>

  {/* Trust Badges */}
  <section class="py-8 bg-stone-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <TrustBadges variant="dark" />
    </div>
  </section>

  {/* Pakiety */}
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-8">
        {/* Audyt */}
        <div class="bg-white rounded-xl p-8 card-brutal">
          <h2 class="text-xl font-bold mb-1">Audyt danych</h2>
          <p class="text-accent font-extrabold text-3xl mb-4">2 000–4 000 zł</p>
          <p class="text-gray-500 text-sm mb-6">Czas realizacji: 3–5 dni roboczych</p>
          <ul class="text-gray-700 space-y-3 mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Pełna diagnoza konfiguracji GA4</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Analiza tagów Meta Pixel / Google Ads</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Przegląd konfiguracji GTM</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Raport z rekomendacjami naprawczymi</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Szacunek utraty danych</span>
            </li>
          </ul>
          <p class="text-gray-500 text-xs">Idealne na start — dowiedz się, ile danych tracisz.</p>
        </div>

        {/* BASIC */}
        <div class="bg-white rounded-xl p-8 card-brutal">
          <h2 class="text-xl font-bold mb-1">BASIC</h2>
          <p class="text-accent font-extrabold text-3xl mb-4">5 000–8 000 zł</p>
          <p class="text-gray-500 text-sm mb-6">Czas realizacji: 5–10 dni roboczych</p>
          <ul class="text-gray-700 space-y-3 mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>GTM Server-Side container</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>GA4 server-side z deduplikacją</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Meta Conversions API (CAPI)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Hosting Stape.io + custom domain</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Konfiguracja server-side cookies</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Testy i walidacja danych</span>
            </li>
          </ul>
          <p class="text-gray-500 text-xs">Dla firm, które chcą odzyskać dane z GA4 i Meta.</p>
        </div>

        {/* PRO */}
        <div class="bg-white rounded-xl p-8 card-brutal-accent relative">
          <span class="absolute -top-3 left-6 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full">
            Najpopularniejszy
          </span>
          <h2 class="text-xl font-bold mb-1">PRO</h2>
          <p class="text-accent font-extrabold text-3xl mb-4">8 000–14 000 zł</p>
          <p class="text-gray-500 text-sm mb-6">Czas realizacji: 10–14 dni roboczych</p>
          <ul class="text-gray-700 space-y-3 mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Wszystko z pakietu BASIC</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Google Ads Enhanced Conversions</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>TikTok Events API</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Consent Mode v2 (pełna konfiguracja)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Zaawansowany event matching</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Dokumentacja techniczna wdrożenia</span>
            </li>
          </ul>
          <p class="text-gray-500 text-xs">Pełne wdrożenie dla firm z&nbsp;poważnym budżetem reklamowym.</p>
        </div>

        {/* Opieka */}
        <div class="bg-white rounded-xl p-8 card-brutal">
          <h2 class="text-xl font-bold mb-1">Opieka miesięczna</h2>
          <p class="text-accent font-extrabold text-3xl mb-4">800–2 000 zł<span class="text-lg font-normal text-gray-500">/mies.</span></p>
          <p class="text-gray-500 text-sm mb-6">Ciągły monitoring i wsparcie</p>
          <ul class="text-gray-700 space-y-3 mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Monitoring poprawności danych</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Alerty o problemach z trackingiem</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Miesięczny raport jakości danych</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Debugging i naprawa problemów</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent font-bold mt-0.5">✓</span>
              <span>Aktualizacje tagów i konfiguracji</span>
            </li>
          </ul>
          <p class="text-gray-500 text-xs">Spokój ducha — Twój tracking działa bez przerw.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Porównanie pakietów */}
  <PackageComparison />

  {/* FAQ */}
  <section class="py-16 md:py-20 bg-stone-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">
        Najczęściej zadawane pytania
      </h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <details class="group bg-white rounded-xl accordion-brutal overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-primary hover:bg-stone-50 transition-colors">
              <span>{item.q}</span>
              <svg
                class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 shrink-0 ml-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16 md:py-20 bg-primary text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">
        Nie wiesz, który pakiet? Zacznij od rozmowy
      </h2>
      <p class="text-gray-300 mb-8">
        W 30 minut ocenimy Twój obecny tracking i dobierzemy optymalny zakres wdrożenia.
      </p>
      <a
        href="/kontakt"
        class="inline-block bg-accent hover:bg-accent-dark text-white font-semibold px-8 py-4 rounded-lg text-lg btn-brutal-light"
      >
        Umów bezpłatną rozmowę
      </a>
    </div>
  </section>
</Layout>
